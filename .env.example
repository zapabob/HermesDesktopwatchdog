# Environment template (do not commit real secrets)

# Required for mutating Admin API (pause/resume/cycle/stop)
HERMES_WATCHDOG_ADMIN_TOKEN=

# Optional dedicated token for POST /api/v1/heartbeat (falls back to admin token)
# HERMES_WATCHDOG_HEARTBEAT_TOKEN=

# Optional Tailscale tsnet auth key
HERMES_WATCHDOG_TS_AUTHKEY=

# Optional override (also accepted by Start script / binary)
# HERMES_HOME=%USERPROFILE%\.hermes
